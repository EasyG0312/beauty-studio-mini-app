# Environment Configuration for Beauty Studio
# =============================================

# Database Configuration
DB_PASSWORD=beautystudio123
DATABASE_URL=postgresql+asyncpg://postgres:beautystudio123@postgres:5432/beauty_studio

# Redis Configuration
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379/0

# Application Configuration
SECRET_KEY=your-super-secret-key-change-in-production-32-chars-min
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Push Notifications Configuration
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_PUBLIC_KEY=your-vapid-public-key

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Frontend Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_ENVIRONMENT=development

# Monitoring Configuration
GRAFANA_PASSWORD=admin123

# SSL Configuration (for production)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
S3_BUCKET=beauty-studio-backups
AWS_ACCESS_KEY=your-aws-access-key
AWS_SECRET_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Security Configuration
JWT_SECRET_KEY=your-jwt-secret-key-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# File Upload Configuration
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_RETENTION_DAYS=365

# Logging Configuration
LOG_FORMAT=json
LOG_FILE_PATH=/app/logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5
