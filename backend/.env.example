# Beauty Studio Backend Environment Variables
# Скопируйте этот файл в .env и заполните значениями

# Telegram Bot
BOT_TOKEN=1234567890:AAFZs...
ADMIN_CHAT_ID=338067005

# Admin IDs (comma-separated)
ADMIN_IDS=338067005
OWNER_IDS=338067005

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT Settings
JWT_SECRET=your_secret_key_here
JWT_ALGORITHM=HS256

# CORS (comma-separated origins)
CORS_ORIGINS=https://your-app.vercel.app,https://telegram.org

# Business Settings
BUSINESS_NAME=Beauty Studio Bishkek
PHONE=+996 707 001112
ADDRESS=г. Бишкек, ул. Ахунбаева, 1
WORKING_HOURS=Пн-Сб: 09:00 - 20:00
